## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio 2015+ cache/options directory
.vs/

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Database
*.db
*.db-shm
*.db-wal

# Environment files
.env
*.env

# OS files
.DS_Store
Thumbs.db

# Uploaded files (for local dev)
uploads/
temp/